<!-- Google Tag Manager -->
<script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
})(window,document,'script','dataLayer','GTM-M4BZX8MB');</script>
<!-- End Google Tag Manager -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<% resource_title = strip_html(strip_newlines(title)) %>
<title><% if resource_title != "Index" %><%= resource_title %> | <%= metadata.title %><% else %><%= metadata.title %>: <%= metadata.tagline %><% end %></title>

<meta name="description" content="<%= metadata.description %>" />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content="https://karimtarek.com<%= relative_url '/' %>" />
<meta property="og:title" content="<%= resource_title != 'Index' ? "#{resource_title} | #{metadata.title}" : "#{metadata.title}: #{metadata.tagline}" %>" />
<meta property="og:description" content="<%= metadata.description %>" />
<meta property="og:image" content="https://karimtarek.com<%= relative_url '/images/karim.jpg' %>" />

<!-- Twitter / X -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="<%= resource_title != 'Index' ? "#{resource_title} | #{metadata.title}" : "#{metadata.title}: #{metadata.tagline}" %>" />
<meta name="twitter:description" content="<%= metadata.description %>" />
<meta name="twitter:image" content="https://karimtarek.com<%= relative_url '/images/karim.jpg' %>" />

<!-- Canonical -->
<link rel="canonical" href="https://karimtarek.com<%= relative_url resource.relative_url %>" />

<link rel="stylesheet" href="<%= asset_path :css %>" />
<script src="<%= asset_path :js %>" defer></script>
<%= live_reload_dev_js %>
