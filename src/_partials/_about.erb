<div class="relative isolate overflow-hidden bg-white py-12 sm:py-16 dark:bg-gray-900">
  <div aria-hidden="true" class="absolute -top-80 left-[max(6rem,33%)] -z-10 transform-gpu blur-3xl sm:left-1/2 md:top-20 lg:ml-20 xl:top-3 xl:ml-56">
    <div style="clip-path: polygon(63.1% 29.6%, 100% 17.2%, 76.7% 3.1%, 48.4% 0.1%, 44.6% 4.8%, 54.5% 25.4%, 59.8% 49.1%, 55.3% 57.9%, 44.5% 57.3%, 27.8% 48%, 35.1% 81.6%, 0% 97.8%, 39.3% 100%, 35.3% 81.5%, 97.2% 52.8%, 63.1% 29.6%)" class="aspect-801/1036 w-200.25 bg-linear-to-tr from-[#ff80b5] to-[#9089fc] opacity-30"></div>
  </div>
  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="mx-auto max-w-2xl lg:mx-0">
      <p class="text-base/7 font-semibold text-indigo-600 dark:text-indigo-400"><%= data.about.section_label %></p>
      <h2 class="mt-2 text-4xl font-semibold tracking-tight text-pretty text-gray-900 sm:text-5xl dark:text-white"><%= data.about.section_title %></h2>
      <p class="mt-6 text-xl/8 text-gray-700 dark:text-gray-300"><%= data.about.paragraphs[0] %></p>
    </div>
    <div class="mx-auto mt-16 grid max-w-2xl grid-cols-1 gap-x-8 gap-y-16 lg:mx-0 lg:mt-10 lg:max-w-none lg:grid-cols-12">
      <div class="relative lg:order-last lg:col-span-5">
        <svg aria-hidden="true" class="absolute -top-160 left-1 -z-10 h-256 w-702 -translate-x-1/2 mask-[radial-gradient(64rem_64rem_at_111.5rem_0%,white,transparent)] stroke-gray-900/10">
          <defs>
            <pattern id="e87443c8-56e4-4c20-9111-55b82fa704e3" width="200" height="200" patternUnits="userSpaceOnUse">
              <path d="M0.5 0V200M200 0.5L0 0.499983" />
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#e87443c8-56e4-4c20-9111-55b82fa704e3)" stroke-width="0" />
        </svg>
        <figure class="border-l border-indigo-600 pl-8">
          <blockquote class="text-xl/8 font-semibold tracking-tight text-gray-900 dark:text-white">
            <p>"<%= data.about.qoute.body %>"</p>
          </blockquote>
          <figcaption class="mt-8 flex gap-x-4">
            <img src='<%= relative_url "/images/#{data.about.qoute.thumb}" %>' alt="<%= data.about.qoute.name %> | <%= data.about.qoute.title %>" class="mt-1 size-10 flex-none rounded-full bg-gray-50 dark:bg-gray-700" />
            <div class="text-sm/6">
              <div class="font-semibold text-gray-900 dark:text-white"><%= data.about.qoute.name %></div>
              <div class="text-gray-600 dark:text-gray-400"><%= data.about.qoute.title %></div>
            </div>
          </figcaption>
        </figure>
      </div>
      <div class="max-w-xl text-base/7 text-gray-600 dark:text-gray-400 lg:col-span-7">
        <p><%= markdownify(data.about.paragraphs[1]) %></p>
        <p class="mt-8"><%= data.about.paragraphs[2] %></p>
        <p class="mt-8"><%= data.about.paragraphs[3] %></p>
      </div>
    </div>
  </div>
</div>
